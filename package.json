{
  "name": "fluxer-rpc",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.11"
  },
  "version": "0.1.0",
  "scripts": {
    "start": "bun .",
    "dev": "bun --watch . --dry",
    "exe": "bun build . --compile --target=bun-windows-x64 --define 'IS_WINDOWS=true' --minify --outfile fluxer-rpc.exe && python scripts/patch.py fluxer-rpc.exe",
    "dev-exe": "bun build . --compile --target=bun-windows-x64 --define 'IS_WINDOWS=true' --minify --outfile fluxer-rpc.exe",
    "env": "bun ./scripts/generate-default-env.ts --gen",
    "env-gen": "bun ./scripts/generate-default-env.ts --write",
    "tag": "git tag v$(node -p \"require('./package.json').version\")",
    "clear-tags": "pwsh -Command \"git tag | % { git tag -d $_ }\"",
    "push-tags": "git push --tags"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.10",
    "dotenv": "^17.3.1",
    "ky": "^1.14.3",
    "open": "^11.0.0",
    "systray": "^1.0.5",
    "zod": "^4.3.6"
  }
}
